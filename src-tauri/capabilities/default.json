{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "store:default",
    "opener:default",
    "fs:default",
    "fs:read-all",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-applocaldata-write-recursive",
    "fs:allow-applocaldata-read-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA/*" },
        { "path": "$APPLOCALDATA/**" }
      ]
    }
  ]
}
